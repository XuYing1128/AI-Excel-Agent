__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
.env
data/private/
build/
dist/
*.egg-info/
.DS_Store
Thumbs.db

# Local inputs, temporary files, and backups may contain sensitive data.
inputs/
temp/
backups/

# Generated task artifacts stay local. Keep the directory structure in Git.
outputs/tasks/*
!outputs/tasks/.gitkeep
outputs/legacy/*
!outputs/legacy/.gitkeep
outputs/manifest.json

# Legacy root-level outputs are ignored until archived by the V1 helper.
outputs/*.xlsx
outputs/*.xlsm
outputs/*.json
outputs/*.md
!outputs/.gitkeep

# 本地真实任务验证的运行产物（result.xlsx、run_log、agent_tmp 等），不入库。
outputs/_*/
outputs/ai_agent_benchmark/

# Temporary Office lock files.
~$*.xlsx
~$*.xlsm
~$*.docx
